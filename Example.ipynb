import numpy as np
import matplotlib.pyplot as plt
import ipywidgets as widgets
from IPython.display import display, clear_output

def plot_budget_line(Px, Py, I):
    # Intercepts
    x_int = I / Px
    y_int = I / Py

    # Axis limits with padding (auto-scaling)
    x_max = 1.25 * x_int
    y_max = 1.25 * y_int

    x_vals = np.linspace(0, x_int, 400)
    y_vals = (I - Px * x_vals) / Py

    plt.figure(figsize=(8, 6))

    # Budget line
    plt.plot(x_vals, y_vals, linewidth=2.5, label="Budget line")

    # Shade affordable set
    plt.fill_between(x_vals, 0, y_vals, alpha=0.25, label="Affordable bundles")

    # Intercepts
    plt.scatter([x_int], [0], color="red", zorder=5)
    plt.scatter([0], [y_int], color="red", zorder=5)

    # Labels for intercepts
    plt.annotate(
        f"All income spent on X\n($x=I/P_x={x_int:.1f}$)",
        (x_int, 0),
        xytext=(0.9 * x_int, 0.15 * y_int),
        arrowprops=dict(arrowstyle="->"),
        fontsize=10,
    )

    plt.annotate(
        f"All income spent on Y\n($y=I/P_y={y_int:.1f}$)",
        (0, y_int),
        xytext=(0.15 * x_int, 0.9 * y_int),
        arrowprops=dict(arrowstyle="->"),
        fontsize=10,
    )

    # Labels and title
    plt.xlabel("Quantity of Good X")
    plt.ylabel("Quantity of Good Y")
    plt.title(
        f"Budget Line and Affordable Set\n"
        f"Income = {I},  Px = {Px},  Py = {Py}"
    )

    plt.xlim(0, x_max)
    plt.ylim(0, y_max)
    plt.grid(alpha=0.3)
    plt.legend(loc="upper right")

    plt.show()

# --- Widgets ---
Px_box = widgets.BoundedIntText(
    value=5, min=1, max=20, step=1,
    description="Price of X (1–20):",
    style={"description_width": "initial"},
)

Py_box = widgets.BoundedIntText(
    value=4, min=1, max=20, step=1,
    description="Price of Y (1–20):",
    style={"description_width": "initial"},
)

I_box = widgets.BoundedIntText(
    value=100, min=50, max=500, step=10,
    description="Income I (50–500):",
    style={"description_width": "initial"},
)

generate_btn = widgets.Button(description="Generate Budget Line", button_style="success")
out = widgets.Output()

def on_generate(_):
    with out:
        clear_output(wait=True)
        plot_budget_line(Px_box.value, Py_box.value, I_box.value)

generate_btn.on_click(on_generate)

display(
    widgets.VBox([
        widgets.HBox([Px_box, Py_box, I_box]),
        generate_btn,
        out
    ])
)

# Run once by default
on_generate(None)